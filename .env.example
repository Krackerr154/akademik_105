# Akademik 105 — Environment Variables

# ─── NextAuth ────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ─── Google OAuth (Login) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Superadmin Bootstrap ────────────────────────────────────────────
SUPERADMIN_EMAILS=superadmin@example.com

# ─── Turso Database ─────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# ─── Google Sheets (GForm Sync) — SEPARATE service account ──────────
GSHEETS_CLIENT_EMAIL=
GSHEETS_PRIVATE_KEY=

# ─── Google Drive A ─────────────────────────────────────────────────
GDRIVE_A_CLIENT_EMAIL=
GDRIVE_A_PRIVATE_KEY=
GDRIVE_A_FOLDER_ID=

# ─── Google Drive B ─────────────────────────────────────────────────
GDRIVE_B_CLIENT_EMAIL=
GDRIVE_B_PRIVATE_KEY=
GDRIVE_B_FOLDER_ID=

# ─── Public ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GFORM_URL=https://docs.google.com/forms/d/e/your-form-id/viewform
